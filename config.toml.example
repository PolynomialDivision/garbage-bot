[matrix]
homeserver = "https://matrix.org"
user_id = "@yourbotname:matrix.org"
access_token = "YOUR_ACCESS_TOKEN"
device_id = "YOUR_DEVICE_ID"
# Optional: security key from Element's "Set up Secure Backup"
# Needed once to self-sign the bot's device (removes "not verified by owner" warning).
# Steps: log in as bot in Element Web → Settings → Security → Set up Secure Backup → generate key
# After first successful run showing "Cross-signing bootstrapped", remove this line.
# recovery_key = "EsXX xxxx xxxx xxxx xxxx xxxx xxxx xxxx"

[bsr]
# Option A: let the bot resolve your schedule_id from your address at startup.
# The resolved ID is logged — copy it into Option B for faster future startups.
street = "Musterstraße"
number = "1"
plz = "12345"

# Option B: set schedule_id directly (faster startup, skip the API lookup).
# schedule_id = "YOUR_SCHEDULE_ID"

# Optional: Berlin Recycling customer portal for paper (Altpapier) collection.
# If omitted, only BSR pickups are tracked.
# Register at https://kundenportal.berlin-recycling.de/
[berlin_recycling]
username = "your@email.de"
password = "yourpassword"
# If your password contains backslashes or special chars, use single quotes:
# password = 'your\password'

[reminder]
# Local time (24h) to send the reminder the evening before pickup
reminder_time = "20:00"

[security]
# Users allowed to issue !reset-trust @user:server
admin_users = ["@you:matrix.org"]

# Only these users may invite the bot to a room.
# If empty, the bot accepts invites from everyone (not recommended).
allowed_inviters = ["@you:matrix.org"]

# Which devices receive room keys:
#   identity_based  — only cross-signed devices (default, recommended)
#   only_trusted    — only explicitly verified devices
#   all_devices     — all devices, no restriction
encryption_strategy = "all_devices"

# Waste type labels (override to customise names shown in reminders)
[waste_labels]
# BSR codes
HM = "Residual Waste (grey)"
BI = "Organic Waste (brown)"
WS = "Recyclables (yellow)"
LT = "Garden Waste (green)"
WB = "Christmas Tree"
# Berlin Recycling labels (after stripping leading category code)
"Altpapier, gemischt" = "Paper (blue)"

# Optional: color each label in the Matrix message (HTML clients only)
[waste_colors]
"Residual Waste (grey)"  = "#808080"
"Organic Waste (brown)"  = "#6B8E23"
"Recyclables (yellow)"   = "#DAA520"
"Garden Waste (green)"   = "#556B2F"
"Christmas Tree"         = "#006400"
"Paper (blue)"           = "#4682B4"
